# ── Configuración del proyecto MLOps Bolivia ─────────────────────────────────
# Copia este archivo como .env y ajusta los valores

# MLflow
MLFLOW_TRACKING_URI=sqlite:///mlflow.db
MLFLOW_EXPERIMENT_NAME=riesgo_metabolico_bolivia
MODEL_NAME=RiesgoMetabolico

# API
API_HOST=0.0.0.0
API_PORT=8000
API_VERSION=v1

# Umbrales de evaluación
MIN_F1_MACRO=0.65          # mínimo para promover a producción
MAX_F1_DROP=0.05           # máximo descenso aceptable vs modelo anterior

# Monitoreo — alertas de drift
DRIFT_IMC_THRESHOLD=0.10   # 10% cambio en media de IMC
DRIFT_CLASS2_THRESHOLD=0.15 # 15% cambio en proporción clase 2

# Ruta de datos
DATA_DIR=data
PROCESSED_DIR=data/processed
MODEL_DIR=models
